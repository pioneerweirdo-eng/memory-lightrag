{
  "name": "memory-lightrag",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "description": "OpenClaw memory plugin with LightRAG-backed search + builtin fallback",
  "main": "src/index.ts",
  "scripts": {
    "verify:intent-rerank": "node --experimental-strip-types test/intent-rerank.verify.mjs",
    "eval:intent-replay": "node --experimental-strip-types eval/run-intent-replay-eval.mjs",
    "eval:intent-replay:legacy": "node --experimental-strip-types eval/run-intent-replay-eval.mjs"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
