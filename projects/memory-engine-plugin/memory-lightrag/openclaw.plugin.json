{
  "id": "memory-lightrag",
  "kind": "memory",
  "configSchema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "lightrag": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "baseUrl": { "type": "string" },
          "apiKey": { "type": "string" },
          "timeout": { "type": "number" }
        }
      },
      "fallbackEnabled": { "type": "boolean" },
      "verbose": { "type": "boolean" },
      "intent": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "scoredRouting": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "enabled": { "type": "boolean" },
              "profile": { "type": "string", "enum": ["strict", "default", "recall"] },
              "minTopScore": { "type": "number" },
              "minMargin": { "type": "number" }
            }
          }
        }
      }
    }
  }
}
